# Copier ce fichier en .env et compléter les valeurs.
# .env n'est jamais versionné (voir .gitignore).

# --- Django ---
DJANGO_SECRET_KEY=change-moi-pour-une-valeur-aleatoire-en-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- Base de données ---
# En développement, laisser vide pour utiliser SQLite (db.sqlite3).
# En production ou pour tester PostgreSQL, renseigner DATABASE_URL :
#   postgres://utilisateur:motdepasse@localhost:5432/portail_educatif
DATABASE_URL=

# --- CORS ---
# Origines autorisées pour l'API depuis le front Vue en dev.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Claude / Anthropic ---
# Clé API pour les appels en production (questions libres).
# NE JAMAIS exposer cette clé côté front.
ANTHROPIC_API_KEY=

# Modèles recommandés (voir docs/prompts_ia.md)
ANTHROPIC_MODEL_GENERATION=claude-sonnet-4-6
ANTHROPIC_MODEL_QUESTIONS_LIBRES=claude-haiku-4-5

# --- Limites et garde-fous ---
QUESTIONS_LIBRES_MAX_PAR_JOUR=5
